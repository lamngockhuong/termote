{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 120,
  "indentWidth": 2,
  "useTabs": false,
  "markdown": {
    "lineWidth": 120,
    "textWrap": "maintain"
  },
  "includes": [
    "**/*.md",
    "**/*.mdx"
  ],
  "excludes": [
    "**/node_modules",
    "**/dist",
    "**/.git",
    "**/CHANGELOG.md",
    "website/**/*.mdx"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.17.8.wasm"
  ]
}
