{
  "name": "termote",
  "private": true,
  "version": "0.0.15",
  "description": "PWA for remotely controlling CLI tools from mobile/desktop",
  "author": "Lam Ngoc Khuong <hi@khuong.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lamngockhuong/termote.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "hammerjs": "2.0.8",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/hammerjs": "2.0.46",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.4"
  }
}
